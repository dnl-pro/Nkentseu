#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Sandbox â€” Application de dÃ©monstration multi-plateformes
=========================================================
Illustre l'utilisation complÃ¨te du framework Nkentseu :
  â€¢ CrÃ©ation de fenÃªtre et boucle principale cross-platform
  â€¢ Gestion des Ã©vÃ©nements : clavier, souris, touch, drag & drop
  â€¢ Rendu pixel software via NKRenderer (NkSoftwareRenderer)
  â€¢ Gamepad, safe area, transforms 2D

Un seul fichier src/main.cpp compile pour TOUTES les plateformes.
Le point d'entrÃ©e natif est abstrait par NkEntry.h / NkMain.h.
"""

from Jenga import *
from Jenga.Core.Api import androidallowrotation
import shutil
import subprocess

def _pkg_exists(pkg_name: str) -> bool:
    if not shutil.which("pkg-config"):
        return False
    try:
        return subprocess.call(
            ["pkg-config", "--exists", pkg_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ) == 0
    except Exception:
        return False

_WAYLAND_LINKS = ["pthread", "wayland-client", "xkbcommon", "wayland-cursor"]
_WAYLAND_TEST_LINKS = ["pthread", "wayland-client", "xkbcommon"]
_WAYLAND_DEFINES = ["NKENTSEU_FORCE_WINDOWING_WAYLAND_ONLY"]
if _pkg_exists("libdecor-0"):
    _WAYLAND_LINKS.append("decor-0")
    _WAYLAND_TEST_LINKS.append("decor-0")
    _WAYLAND_DEFINES.append("NKENTSEU_WAYLAND_LIBDECOR")

def configure_sandbox_app(project_name: str, source_file: str, app_id_suffix: str, needs_camera: bool = False):
    with project(project_name):
        windowedapp()
        language("C++")
        cppdialect("C++17")
        location(".")

        _TC_WINDOWS = "nk-windows-clang-mingw"

        files([source_file])

        includedirs([
            "src",
            "include",
            "%{wks.location}/Externals",
            "%{NKWindow.location}/src",
            "%{NKRenderer.location}/src",
            "%{NKLogger.location}/src",
            "%{NKCore.location}/src",
            "%{NKPlatform.location}/src",
            "%{NKMath.location}/src",
            "%{NKTime.location}/src",
            "%{NKStream.location}/src",
            "%{NKMemory.location}/src",
            "%{NKContainers.location}/src",
        ])

        links([
            "NKWindow", "NKRenderer", "NKLogger",
            "NKMath", "NKTime", "NKStream",
            "NKContainers", "NKMemory", "NKCore", "NKPlatform"
        ])
        dependson([
            "NKWindow", "NKRenderer", "NKLogger",
            "NKMath", "NKTime", "NKStream",
            "NKContainers", "NKMemory", "NKCore", "NKPlatform"
        ])

        objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")
        targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}/%{prj.name}")

        with filter("system:Windows && options:windows-runtime=uwp"):
            objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-uwp/%{prj.name}")
            targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-uwp/%{prj.name}")

        # ===== Windows ================================================================
        with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
            windowedapp()
            usetoolchain(_TC_WINDOWS)
            defines([
                "WIN32_LEAN_AND_MEAN",
                "_UNICODE", "UNICODE",
            ])
            links([
                "user32", "gdi32", "opengl32", "dwmapi", "shell32",
                "xinput", "mf", "mfplat", "mfreadwrite", "mfuuid",
                "uuid", "ole32", "dinput8", "dxguid"
            ])

        # ===== UWP ====================================================================
        with filter("system:UWP || system:Windows && options:windows-runtime=uwp"):
            windowedapp()
            usetoolchain("xbox-clang")
            defines(["NKENTSEU_PLATFORM_UWP"])
            links(["d3d12", "dxgi", "dxguid", "windowsapp"])

        # ===== Linux headless =========================================================
        with filter("system:Linux && options:linux-backend=headless || system:Linux && options:headless"):
            windowedapp()
            usetoolchain("clang-native")
            objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
            targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-headless/%{prj.name}")
            defines(["NKENTSEU_FORCE_WINDOWING_NOOP_ONLY"])
            links(["pthread"])

        # ===== Linux XLib =============================================================
        with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
            windowedapp()
            usetoolchain("clang-native")
            defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])
            links(["pthread", "X11"])

        # ===== Linux XCB ==============================================================
        with filter("system:Linux && options:linux-backend=xcb"):
            windowedapp()
            usetoolchain("clang-native")
            objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
            targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-xcb/%{prj.name}")
            defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])
            links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11-xcb", "xkbcommon", "xkbcommon-x11"])
            ldflags(["-fuse-ld=lld"])

        # ===== Linux Wayland ==========================================================
        with filter("system:Linux && options:linux-backend=wayland"):
            windowedapp()
            usetoolchain("clang-native")
            objdir("%{wks.location}/Build/Obj/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
            targetdir("%{wks.location}/Build/Bin/%{cfg.buildcfg}-%{cfg.system}-wayland/%{prj.name}")
            defines(_WAYLAND_DEFINES)
            links(_WAYLAND_LINKS)

        # ===== macOS ==================================================================
        with filter("system:macOS"):
            windowedapp()
            usetoolchain("clang-native")
            frameworks(["Cocoa", "QuartzCore", "OpenGL"])

        # ===== Android ================================================================
        with filter("system:Android"):
            windowedapp()
            usetoolchain("android-ndk")
            links(["android", "log", "EGL", "GLESv3"])
            androidapplicationid(f"com.nkentseu.{app_id_suffix}")
            androidminsdk(24)
            androidtargetsdk(34)
            androidcompilesdk(34)
            androidabis(["armeabi-v7a", "arm64-v8a", "x86", "x86_64"])
            androidnativeactivity(True)
            androidallowrotation(True)
            androidstl("c++_shared")
            if needs_camera:
                androidpermissions([
                    "android.permission.CAMERA",
                ])

        # ===== iOS ====================================================================
        with filter("system:iOS"):
            windowedapp()
            frameworks(["UIKit", "QuartzCore", "OpenGLES"])
            iosbundleid(f"com.nkentseu.{app_id_suffix}")
            iosversion("1.0")
            iosminsdk("14.0")
            iosbuildnumber(1)

        # ===== Web ====================================================================
        with filter("system:Web"):
            consoleapp()
            usetoolchain("emscripten")
            emscriptencanvasid("canvas")
            emscripteninitialmemory(32)
            emscriptenextraflags([
                "-s", "ASYNCIFY",
                "-s", "DYNAMIC_EXECUTION",
                "-s", "EXPORTED_RUNTIME_METHODS=['ccall','cwrap']",
                "-s", "INITIAL_MEMORY=67108864",
                "-s", "ALLOW_MEMORY_GROWTH=1",
                "-s", "FULL_ES3=1",
                "-s", "USE_WEBGL2=1",
                "-s", "ASSERTIONS=1",
                "-s", "NO_EXIT_RUNTIME=1",
                "-s", "SAFE_HEAP=1",
            ])

        # ===== HarmonyOS ==============================================================
        with filter("system:HarmonyOS"):
            windowedapp()
            links(["log", "EGL", "GLESv3"])

        # ===== Xbox ===================================================================
        with filter("system:XboxSeries || system:XboxOne"):
            windowedapp()
            usetoolchain("xbox-clang")
            links(["d3d12", "dxgi", "dxguid", "xgameruntime"])

        with filter("config:Debug"):
            defines(["_DEBUG"])
            optimize("Off")
            symbols(True)
        with filter("config:Release"):
            defines(["NDEBUG"])
            optimize("Speed")
            symbols(False)

        # Tests unitaires/benchmarks (desktop uniquement)
        with filter("(system:Linux || system:macOS || (system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne)) && !system:Android && !system:iOS && !system:Web"):
            with test():
                testfiles(["tests/**.cpp"])
                with filter("system:Linux && options:linux-backend=wayland"):
                    defines(_WAYLAND_DEFINES)
                    links(_WAYLAND_TEST_LINKS)
                with filter("system:Linux && options:linux-backend=xcb"):
                    defines(["NKENTSEU_FORCE_WINDOWING_XCB_ONLY"])
                    links(["pthread", "xcb", "xcb-image", "xcb-icccm", "xcb-randr", "xcb-xfixes", "X11-xcb", "xkbcommon", "xkbcommon-x11"])
                with filter("system:Linux && options:linux-backend=xlib || system:Linux && !options:linux-backend && !options:headless"):
                    defines(["NKENTSEU_FORCE_WINDOWING_XLIB_ONLY"])
                    links(["pthread", "X11"])
                with filter("system:Windows && !options:windows-runtime=uwp && !system:XboxSeries && !system:XboxOne"):
                    links([
                        "user32", "gdi32", "opengl32", "dwmapi", "shell32",
                        "xinput", "mf", "mfplat", "mfreadwrite", "mfuuid",
                        "uuid", "ole32", "dinput8", "dxguid"
                    ])

configure_sandbox_app("Sandbox", "src/**.cpp", "sandbox")
